{
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "/api/dashboard",
      "permanent": false
    },
    {
      "source": "/manifest.json",
      "destination": "/api/manifest",
      "permanent": false
    },
    {
      "source": "/flow",
      "destination": "/dashboard/options_flow_tab.html",
      "permanent": false
    },
    {
      "source": "/radar",
      "destination": "/api/radar",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Build-Time",
          "value": "1774644561"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/daytrades",
      "destination": "/api/data?_route=daytrades"
    },
    {
      "source": "/api/dna",
      "destination": "/api/data?_route=dna"
    },
    {
      "source": "/api/risk",
      "destination": "/api/data?_route=risk"
    },
    {
      "source": "/api/signals",
      "destination": "/api/data?_route=signals"
    },
    {
      "source": "/api/trade-log",
      "destination": "/api/data?_route=tradelog"
    },
    {
      "source": "/api/news",
      "destination": "/api/data?_route=news"
    },
    {
      "source": "/api/prices",
      "destination": "/api/data?_route=prices"
    }
  ]
}