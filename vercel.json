{
  "framework": null,
  "redirects": [
    { "source": "/", "destination": "/api/dashboard", "permanent": false },
    { "source": "/manifest.json", "destination": "/api/manifest", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, no-cache" }]
    }
  ]
}
