{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/inject_albert_context.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python scripts/hooks/inject_current_truth.py",
            "timeout": 6
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/audit_cli_response.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/preserve_rules_on_compact.py",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
