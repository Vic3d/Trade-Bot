# TradeMind — Secrets
# Kopiere diese Datei nach deploy/.env und fülle die Werte aus:
#   cp deploy/.env.example deploy/.env
#   nano deploy/.env

# Discord Bot Token (PFLICHT — für Trade-Alerts an Victor)
DISCORD_BOT_TOKEN=

# Discord DM Channel ID (Victor)
DISCORD_CHANNEL_ID=1475255728313864413

# Anthropic API Key (OPTIONAL — für Entity Extraction in News)
ANTHROPIC_API_KEY=

# Polygon.io API Key (OPTIONAL — für erweiterte News-Daten)
POLYGON_KEY=

# Finnhub API Key (OPTIONAL — für Markdaten-Backup)
FINNHUB_KEY=
