[Unit]
Description=TradeMind Dashboard API (Port 8765)
After=network.target trademind-scheduler.service

[Service]
Type=simple
User=trademind
Group=trademind
WorkingDirectory=/opt/trademind
ExecStart=/opt/trademind/venv/bin/python3 scripts/api_server.py
Restart=always
RestartSec=5

# Environment
EnvironmentFile=/opt/trademind/deploy/.env
Environment=PYTHONIOENCODING=utf-8
Environment=TRADEMIND_HOME=/opt/trademind

# Logging
StandardOutput=append:/opt/trademind/data/api-server.log
StandardError=append:/opt/trademind/data/api-server.log

# Sicherheit
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/trademind/data /opt/trademind/memory
ReadOnlyPaths=/opt/trademind/scripts
PrivateTmp=true

[Install]
WantedBy=multi-user.target
